{
  "name": "amo-analytics",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "dev:worker:sync": "tsx watch src/workers/sync/full-sync.worker.ts",
    "dev:worker:metrics": "tsx watch src/workers/metrics/metrics.worker.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/server/index.js",
    "migrate": "node dist/lib/db/migrate.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@bull-board/api": "^5.21.0",
    "@bull-board/fastify": "^5.21.0",
    "@clickhouse/client": "^1.4.0",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "axios": "^1.7.2",
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.31.2",
    "fastify": "^4.28.0",
    "ioredis": "^5.3.2",
    "grammy": "^1.27.0",
    "openai": "^4.52.0",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "pino-pretty": "^11.2.0",
    "qs": "^6.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/pg": "^8.11.6",
    "@types/qs": "^6.9.15",
    "drizzle-kit": "^0.22.7",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
